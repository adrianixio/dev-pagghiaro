  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "lib": ["ES2022"],
    "types": ["bun-types"],
    "skipLibCheck": true,
    "paths": {
      "@dev-pagghiaro/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
